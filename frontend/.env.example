# Base backend URL (no trailing slash)
VITE_API_URL=http://127.0.0.1:8000/api

# Auth
VITE_API_AUTH_REGISTER=/auth/register/
VITE_API_AUTH_COMPLETE_PROFILE=/auth/complete-profile/
VITE_API_AUTH_LOGIN=/auth/login/
VITE_API_AUTH_OAUTH=/auth/oauth/
VITE_API_AUTH_ME=/auth/me/
VITE_API_AUTH_PROFILE=/auth/profile/

# Articles
VITE_API_ARTICLES=/articles/

# Shop
VITE_API_SHOP_PRODUCTS=/shop/products/
VITE_API_SHOP_CART=/shop/cart/

# Advisory
VITE_API_ADVISORY_META=/advisory/meta/
VITE_API_ADVISORY_QUESTIONS=/advisory/questions/

# Weather
VITE_API_WEATHER_FORECAST=/weather/forecast/

# Firebase OAuth (required for Google/GitHub login buttons)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
